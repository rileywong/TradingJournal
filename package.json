{
  "name": "tradelytics",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lightweight TradeZella-style trading journal & analytics platform (Light Theme).",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "serve": "npm run build && node server/index.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "lightweight-charts": "^4.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "supertest": "^7.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
