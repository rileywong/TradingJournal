# Greenstreak environment variables. Copy to `.env` for local use, or set these
# in your host's dashboard (Render, etc.). None are required for local dev — the
# app runs with sensible defaults and a built-in dev billing provider.

# ── Core ──────────────────────────────────────────────────────────────────
PORT=4000
# Where the SQLite database lives. Use an absolute path on a persistent disk in
# production; :memory: for an ephemeral store.
DB_PATH=./data/trade.db
# Secret used to HMAC-sign auth tokens. MUST be set to a long random value in
# production (e.g. `openssl rand -hex 32`) — the server refuses to boot in
# production with the insecure default.
TJS_SECRET=

# ── Paywall ───────────────────────────────────────────────────────────────
# Default "true". Set "false" to run open/early-access (everyone gets full
# access; billing code stays wired up). Trial is 14 days; price is $10/month.
PAYWALL_ENABLED=true

# ── Stripe billing (optional — without these, the dev billing provider runs) ─
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
# Public base URL for Stripe redirect/return links. Optional on Render
# (RENDER_EXTERNAL_URL is used automatically). e.g. https://greenstreak.onrender.com
APP_URL=

# ── Social sign-in (optional) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# ── Admin ──────────────────────────────────────────────────────────────────
# Comma-separated emails granted the in-app admin dashboard (site-wide stats:
# users, MRR, subscription funnel, signups). e.g. you@example.com,ops@example.com
ADMIN_EMAILS=

# ── Transactional email (optional) ─────────────────────────────────────────
# Without these, emails (welcome / password reset / weekly digest) only log to
# the console. Set both to actually deliver via Resend (https://resend.com).
RESEND_API_KEY=
# Verified sender. Must match a domain/address verified in Resend.
EMAIL_FROM=Greenstreak <onboarding@resend.dev>
